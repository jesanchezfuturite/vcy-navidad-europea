---
const features = [
  {
    title: "Acompañamiento desde México",
    desc: "Un representante se documenta contigo en la CDMX y vuela en tu mismo avión para guiarte en cada escala.",
    icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
  },
  {
    title: "Logística y traslados totalmente resueltos",
    desc: "Desde tu llegada hasta el regreso, te moverás en un autobús privado exclusivo para el grupo.",
    icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
  },
  {
    title: "Guía profesional en tu idioma",
    desc: "Un guía acompañante coordinará los horarios, los check-ins en los hoteles y te asistirá ante cualquier duda durante todo el viaje.",
    icon: "M3 5h12M9 3v2m1.048 9.5a18.022 18.022 0 01-3.837-5.612m.333-2.113C13.62 6.86 16 10.132 16 13a3 3 0 01-3 3h-1m-4-7a13 13 0 003 10l8-8"
  },
  {
    title: "Expertos locales en cada parada",
    desc: "En cada ciudad principal se sumarán guías locales para los recorridos panorámicos, garantizando que conozcas la historia real y los mejores rincones.",
    icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"
  }
];
---
<section class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl md:text-5xl font-extrabold text-center mb-16 text-gray-900">
      EL RESPALDO QUE NECESITAS AL VIAJAR LEJOS
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map(feature => (
        <div class="p-8 bg-gray-50 rounded-3xl border border-gray-100 transition-all duration-300 hover:bg-white hover:shadow-xl hover:border-emerald-100">
          <div class="w-14 h-14 bg-emerald-600 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg shadow-emerald-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={feature.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4 leading-tight">
            {feature.title}
          </h3>
          <p class="text-gray-600 leading-relaxed">
            {feature.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
