---
---
<section class="relative min-h-screen lg:h-screen flex items-center justify-center overflow-hidden bg-gray-900 text-white py-24 lg:py-0">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/hero.jpg" 
      alt="Navidad Europea" 
      class="w-full h-full object-cover opacity-60"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-gray-900/60 via-transparent to-gray-900/80"></div>
    <!-- Subtle Grid Pattern -->
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
  </div>

  <!-- Navigation Bar -->
  <nav class="absolute top-0 left-0 w-full z-20 py-4 md:py-6">
    <div class="container mx-auto px-6 flex justify-end items-center">
      <div class="flex flex-col items-end gap-2">
        <a href="#ContactForm" class="hidden md:block px-6 py-2 bg-emerald-600/20 backdrop-blur-md border border-white/20 text-white rounded-full hover:bg-emerald-600 transition-colors">
          Contactar ahora
        </a>
        <div class="bg-white/95 backdrop-blur-md p-3 md:p-6 rounded-2xl md:rounded-3xl shadow-2xl border border-white/20">
          <img src="/images/vcy-logo.webp" alt="VCY Logo" class="h-12 md:h-32 lg:h-48 w-auto" />
        </div>
      </div>
    </div>
  </nav>

  <div class="container mx-auto px-6 relative z-10 text-center lg:text-left mt-12 lg:mt-0">
    <div class="max-w-4xl">
      <span class="inline-block px-4 py-1 mb-6 text-xs md:text-sm font-semibold tracking-widest uppercase bg-emerald-600 rounded-full animate-fade-in">
        ¡NAVIDAD EUROPEA!
      </span>
      <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-extrabold leading-tight mb-6 animate-fade-in" style="animation-delay: 0.1s;">
        VIVE ESTA EXPERIENCIA DE <span class="text-emerald-400">19 DÍAS</span> DESCUBRIENDO EL ENCANTO DEL INVIERNO
      </h1>
      
      <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 md:gap-6 mb-8 text-base md:text-xl font-light animate-fade-in" style="animation-delay: 0.2s;">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:h-6 md:w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          19 Días / 17 Noches · Salida: 20 de Dic, 2026
        </div>
      </div>

      <div class="mb-10 animate-fade-in" style="animation-delay: 0.3s;">
        <p class="text-2xl md:text-5xl font-bold text-emerald-400 mb-2">$69,900 MXN</p>
        <p class="text-base md:text-lg opacity-80">(Por persona en habitación doble)</p>
        <p class="mt-4 text-base md:text-xl font-semibold bg-white/10 inline-block px-4 py-2 rounded-lg backdrop-blur-sm border border-white/20">
          Aparta hoy con solo <span class="text-emerald-400">$5,500 MXN</span>
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 animate-fade-in" style="animation-delay: 0.4s;">
        <a href="#ContactForm" class="w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-lg md:text-xl rounded-full transition-all duration-300 transform hover:scale-105 shadow-xl shadow-emerald-900/40 text-center">
          Quiero apartar mi lugar
        </a>
        <p class="text-xs md:text-sm opacity-70 text-center sm:text-left">Cupo limitado · Atención antes y durante el viaje</p>
      </div>
    </div>
  </div>
</section>
