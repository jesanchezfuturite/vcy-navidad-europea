---
---
<section class="relative h-screen flex items-center justify-center overflow-hidden bg-gray-900 text-white">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/hero.jpg" 
      alt="Navidad Europea" 
      class="w-full h-full object-cover opacity-60"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-gray-900/60 via-transparent to-gray-900/80"></div>
    <!-- Subtle Grid Pattern -->
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 text-center lg:text-left">
    <div class="max-w-4xl">
      <span class="inline-block px-4 py-1 mb-6 text-sm font-semibold tracking-widest uppercase bg-emerald-600 rounded-full animate-fade-in">
        NAVIDAD EUROPEA 2026
      </span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold leading-tight mb-6 animate-fade-in" style="animation-delay: 0.1s;">
        EUROPA NAVIDEÑA MÁGICA: <span class="text-emerald-400">19 DÍAS</span> PARA VIVIR LA NOCHEBUENA EN PARÍS Y AÑO NUEVO EN ROMA
      </h1>
      
      <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 mb-8 text-lg md:text-xl font-light animate-fade-in" style="animation-delay: 0.2s;">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          19 Días / 17 Noches · Salida: 20 de Dic, 2026
        </div>
      </div>

      <div class="mb-10 animate-fade-in" style="animation-delay: 0.3s;">
        <p class="text-3xl md:text-5xl font-bold text-emerald-400 mb-2">$69,900 MXN</p>
        <p class="text-lg opacity-80">(Por persona en habitación doble)</p>
        <p class="mt-4 text-xl font-semibold bg-white/10 inline-block px-4 py-2 rounded-lg backdrop-blur-sm border border-white/20">
          Aparta hoy con solo <span class="text-emerald-400">$5,500 MXN</span>
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 animate-fade-in" style="animation-delay: 0.4s;">
        <a href="#ContactForm" class="px-10 py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xl rounded-full transition-all duration-300 transform hover:scale-105 shadow-xl shadow-emerald-900/40">
          Quiero apartar mi lugar
        </a>
        <p class="text-sm opacity-70">Cupo limitado · Atención antes y durante el viaje</p>
      </div>
    </div>
  </div>
</section>
