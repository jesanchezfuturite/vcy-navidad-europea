---
---
<section class="relative min-h-screen lg:h-screen flex items-center justify-center overflow-hidden bg-gray-900 text-white py-24 lg:py-0">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/hero.jpg" 
      alt="Navidad Europea" 
      class="w-full h-full object-cover opacity-60"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-gray-900/60 via-transparent to-gray-900/80"></div>
    <!-- Subtle Grid Pattern -->
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
  </div>

  <!-- Navigation Bar -->
  <nav class="absolute top-0 left-0 w-full z-20 py-4 md:py-6">
    <div class="container mx-auto px-6 flex justify-end items-center">
      <div class="flex flex-col items-end gap-2">
        <a href="#ContactForm" class="hidden md:block px-6 py-2 bg-green-700/80 backdrop-blur-md border border-white/20 text-white rounded-full hover:bg-green-600 transition-colors animate-fade-in">
          Contactar ahora
        </a>
      </div>
    </div>
  </nav>

  <div class="container mx-auto px-6 relative z-10 text-center lg:text-left mt-8 lg:mt-0">
    <!-- Logo posicionado a la derecha absoluta en pantallas grandes (alineado con el botón superior) -->
    <img src="/images/vcy-logo-bco.png" alt="VCY Logo" class="hidden lg:block absolute right-6 top-8 xl:top-12 h-32 lg:h-48 w-auto drop-shadow-[0_0_15px_rgba(255,255,255,0.7)] animate-fade-in" style="animation-delay: 0.15s;" />

    <div class="max-w-4xl">
      <span class="inline-block px-4 py-1 mb-4 text-xs md:text-sm font-semibold tracking-widest uppercase bg-green-700 rounded-full animate-fade-in">
        ¡NAVIDAD EUROPEA!
      </span>
      <!-- Logo en móviles centrado sobre el título -->
      <img src="/images/vcy-logo-bco.png" alt="VCY Logo" class="lg:hidden h-24 w-auto drop-shadow-[0_0_15px_rgba(255,255,255,0.7)] animate-fade-in mx-auto mb-4" style="animation-delay: 0.15s;" />
      <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl font-black leading-tight text-yellow-500 drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)] animate-fade-in mb-4" style="animation-delay: 0.1s;">
        NAVIDAD EN EUROPA
      </h1>
      <p class="text-2xl md:text-4xl font-bold mb-6 text-white drop-shadow-lg animate-fade-in" style="animation-delay: 0.2s;">
        19 Días de Magia Invernal
      </p>
      
      <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4 md:gap-6 mb-6 text-base md:text-lg font-medium animate-fade-in" style="animation-delay: 0.25s;">
        <div class="flex items-center gap-2 bg-black/20 backdrop-blur-sm px-4 py-2 rounded-full border border-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          Salida: 20 de Dic, 2026
        </div>
      </div>

      <div class="mb-8 animate-fade-in" style="animation-delay: 0.3s;">
        <div class="flex flex-col lg:flex-row lg:items-end gap-2 lg:gap-4">
          <p class="text-3xl md:text-6xl font-black text-yellow-500 drop-shadow-md">$69,900 MXN</p>
          <p class="text-sm md:text-base opacity-90 mb-2">(Por persona en hab. doble)</p>
        </div>
        <p class="mt-2 text-sm md:text-lg font-bold bg-white/10 inline-block px-4 py-2 rounded-lg backdrop-blur-sm border border-white/20">
          Aparta hoy con solo <span class="text-yellow-500">$5,500 MXN</span>
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 animate-fade-in" style="animation-delay: 0.4s;">
        <a href="#ContactForm" class="w-full sm:w-auto px-8 py-4 md:px-10 md:py-5 bg-green-700 hover:bg-green-600 text-white font-bold text-lg md:text-xl rounded-full transition-all duration-300 transform hover:scale-105 shadow-xl shadow-green-900/40 text-center">
          Quiero apartar mi lugar
        </a>
        <p class="text-xs md:text-sm opacity-70 text-center sm:text-left">Cupo limitado · Atención antes y durante el viaje</p>
      </div>
    </div>
  </div>
</section>
